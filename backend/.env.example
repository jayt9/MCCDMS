# ─── Supabase ─────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Project Settings → API

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # Never expose this to the frontend

# ─── App ──────────────────────────────────────────────────────
PORT=3000
FRONTEND_URL=http://localhost:5173    # In prod: your Vercel URL e.g. https://mcc.vercel.app
